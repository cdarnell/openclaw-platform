[ req ]
default_bits        = 4096
prompt              = no
default_md          = sha256
distinguished_name  = dn
req_extensions      = v3_req

[ dn ]
C  = US
ST = GentooFoo
L  = SecureCity
O  = GentooFoo
OU = Security
CN = GentooFoo Issuing CA 01

[ v3_req ]
basicConstraints    = CA:true
keyUsage            = critical, digitalSignature, cRLSign, keyCertSign
subjectKeyIdentifier=hash
